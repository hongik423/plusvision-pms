{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm install && npm run db:generate && npm install --prefix src",
  "buildCommand": "touch .env 2>/dev/null || true && npm run build",
  "regions": ["icn1"],
  "crons": [
    {
      "path": "/api/v1/drive/cron",
      "schedule": "0 0 * * *"
    }
  ]
}
