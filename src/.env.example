# ============================================
# PlusPMS 환경 변수 템플릿 (.env.example)
# 이 파일을 복사하여 .env.local 로 사용하세요:
#   cp .env.example .env.local
# ============================================

# ── Database (Supabase PostgreSQL) ──────────────────────────
# Supabase 프로젝트 > Settings > Database > Connection String
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres?connection_limit=3

# ── Supabase ───────────────────────────────────────────────
# Supabase 프로젝트 > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[ANON_KEY]
SUPABASE_SERVICE_ROLE_KEY=[SERVICE_ROLE_KEY]

# ── NextAuth ───────────────────────────────────────────────
# 배포 URL (예: https://your-app.vercel.app)
NEXTAUTH_URL=http://localhost:3001
# openssl rand -base64 32 로 생성
NEXTAUTH_SECRET=[GENERATE_WITH: openssl rand -base64 32]

# ── Google OAuth 2.0 ───────────────────────────────────────
# Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=[YOUR_CLIENT_ID].apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=[YOUR_CLIENT_SECRET]
NEXT_PUBLIC_GOOGLE_CLIENT_ID=[YOUR_CLIENT_ID].apps.googleusercontent.com

# ── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="PlusPMS"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Google Drive 마이그레이션 (선택) ────────────────────────
# npx tsx scripts/migration/oauth-setup.ts 실행 후 발급
# GOOGLE_DRIVE_REFRESH_TOKEN=
# GOOGLE_DRIVE_SOURCE_FOLDER_ID=
# MIGRATION_TARGET_PROJECT_ID=
# MIGRATION_DEFAULT_UPLOADER_ID=
# MIGRATION_LIMIT=10
# MIGRATION_RECURSIVE=true

# ── SMTP 이메일 (선택) ──────────────────────────────────────
# Gmail: smtp.gmail.com / 587 / 앱 비밀번호 사용
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=[APP_PASSWORD]
# SMTP_FROM=noreply@plusvision.co.kr
