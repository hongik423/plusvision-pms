{
  "name": "plusvision-pms",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node -r ./dev-preload.cjs ./node_modules/next/dist/bin/next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run type-check && npm run test && npm run build",
    "db:push": "prisma db push --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "db:generate": "npx prisma@5.20.0 generate --schema prisma/schema.prisma",
    "db:oauth": "tsx scripts/migration/oauth-setup.ts",
    "db:studio": "prisma studio --schema prisma/schema.prisma",
    "migration:dry-run": "tsx scripts/migration/dry-run.ts",
    "migration:gdrive-dry-run": "tsx scripts/migration/gdrive-dry-run.ts",
    "migration:gdrive-run": "tsx scripts/migration/gdrive-migrate.ts",
    "migration:verify": "tsx scripts/verification/verify-integrity.ts",
    "drive:link-personal": "tsx scripts/migration/link-personal-drive-folders.ts",
    "postinstall": "prisma generate --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "@prisma/client": "^5.20.0",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@supabase/supabase-js": "^2.45.0",
    "@types/nodemailer": "^7.0.11",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.1.0",
    "lucide-react": "^0.440.0",
    "next": "14.2.0",
    "next-auth": "^4.24.0",
    "nodemailer": "^7.0.13",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.53.0",
    "recharts": "^2.12.0",
    "tailwind-merge": "^2.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.0",
    "zustand": "^4.5.0"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "14.2.0",
    "postcss": "^8.4.0",
    "prisma": "5.20.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.8"
  }
}
