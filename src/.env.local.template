# ============================================
# PlusPMS 개발 환경 변수 템플릿 (.env.local)
# 복사 후 실제 값 입력:
# - Windows: copy .env.local.template .env.local
# - Mac/Linux: cp .env.local.template .env.local
# ============================================

# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:[DEV-DB-PASSWORD]@db.[DEV-PROJECT-REF].supabase.co:5432/postgres"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://[DEV-PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[DEV-ANON-KEY]"
SUPABASE_SERVICE_ROLE_KEY="[DEV-SERVICE-ROLE-KEY]"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="[DEV-SECRET-32-CHARS-OR-MORE]"

# Google OAuth (선택)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Google Drive Migration (선택)
GOOGLE_DRIVE_ACCESS_TOKEN=""
GOOGLE_DRIVE_SOURCE_FOLDER_ID=""
MIGRATION_TARGET_PROJECT_ID=""
MIGRATION_DEFAULT_UPLOADER_ID=""
MIGRATION_LIMIT="0"

# App
NEXT_PUBLIC_APP_NAME="PlusPMS"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
